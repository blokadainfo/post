---
/* eslint-disable astro/no-set-html-directive */
import Layout from '@layouts/Template.astro';
import LogoSvg from '@assets/brand/logos/logo.svg?raw';
import TitleLineLongSvg from '@assets/templates/accents/title/long.svg?raw';
import TitleLineShortSvg from '@assets/templates/accents/title/short.svg?raw';
---

<Layout viewportWidth={1080}>
  <!-- 1080×1920 canvas -->
  <div id="post" class="relative h-[1920px] w-[1080px] overflow-hidden bg-black">
    <!-- Foreground content -->
    <div
      class="absolute inset-0 z-30 flex items-center p-8 pb-40 font-['Akzidenz-Grotesk_Pro'] text-white"
    >
      <!-- Main text block -->
      <div class="mx-auto mb-20 w-full max-w-[920px]">
        <!-- Paragraph -->
        <div class="-mb-32 ml-[11.5rem] max-w-[calc(100%-11.5rem)] font-bold font-stretch-normal">
          <p
            id="paragraph"
            class="max-w-full text-[46px] leading-tight text-pretty whitespace-pre-line drop-shadow-lg"
          >
          </p>
        </div>

        <!-- Accent lines + logo (flow below text) -->
        <div class="mt-8 flex max-w-full items-end gap-10">
          <span
            role="img"
            aria-label="Logo"
            class="mb-7 size-36 drop-shadow-lg [&_svg]:block [&_svg]:size-full"
            set:html={LogoSvg}
          />
          <div class="min-w-0 flex-1 space-y-1">
            <span
              aria-hidden="true"
              class="block w-full [&_svg]:block [&_svg]:h-auto [&_svg]:w-full"
              set:html={TitleLineLongSvg}
            />
            <span
              aria-hidden="true"
              class="block w-5/12 [&_svg]:block [&_svg]:h-auto [&_svg]:w-full"
              set:html={TitleLineShortSvg}
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Hairline fix -->
    <div class="pointer-events-none absolute inset-0 z-40 shadow-[inset_0_0_0_1px_#000]"></div>
  </div>
</Layout>
