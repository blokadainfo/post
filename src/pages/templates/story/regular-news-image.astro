---
/* eslint-disable astro/no-set-html-directive */
import Layout from '@layouts/Template.astro';
import LogoSvg from '@assets/brand/logos/logo.svg?raw';
import TitleLineLongSvg from '@assets/templates/accents/title/long.svg?raw';
import TitleLineShortSvg from '@assets/templates/accents/title/short.svg?raw';
---

<Layout viewportWidth={1080}>
  <!-- 1080×1920 canvas -->
  <div id="post" class="relative h-[1920px] w-[1080px] overflow-hidden bg-black">
    <!-- Background image -->
    <div class="relative flex w-full items-center justify-center overflow-hidden">
      <div class="relative z-0 w-full">
        <img id="bg" alt="" aria-hidden="true" class="w-full object-contain" />

        <div class="pointer-events-none absolute inset-0">
          <div
            class="absolute inset-0 bg-gradient-to-b from-black from-5% via-transparent to-transparent"
          >
          </div>
          <div
            class="absolute inset-0 bg-gradient-to-t from-black from-5% via-transparent to-transparent"
          >
          </div>
        </div>
      </div>
    </div>

    <!-- Darken overlay -->
    <div id="shade" class="pointer-events-none absolute inset-0 z-10 bg-black" style="opacity: 0;">
    </div>

    <!-- Foreground content -->
    <div class="absolute inset-0 z-30 p-8 font-['Akzidenz-Grotesk_Pro'] text-white">
      <!-- Main text block -->
      <div class="absolute right-20 bottom-72 left-20">
        <!-- Paragraph -->
        <div
          class="relative z-10 -mb-24 ml-[11.5rem] max-w-[calc(100%-11.5rem)] font-bold font-stretch-normal"
        >
          <p
            id="paragraph"
            class="max-w-full text-[46px] leading-tight text-pretty whitespace-pre-line drop-shadow-lg"
          >
          </p>
        </div>
        <!-- Accent lines -->
        <div class="relative z-0 flex max-w-full items-end gap-10">
          <!-- Logo -->
          <span
            role="img"
            aria-label="Logo"
            class="mb-7 size-36 drop-shadow-lg [&_svg]:block [&_svg]:size-full"
            set:html={LogoSvg}
          />
          <div class="min-w-0 flex-1 space-y-1">
            <span
              aria-hidden="true"
              class="block w-full [&_svg]:block [&_svg]:h-auto [&_svg]:w-full"
              set:html={TitleLineLongSvg}
            />
            <span
              aria-hidden="true"
              class="block w-5/12 [&_svg]:block [&_svg]:h-auto [&_svg]:w-full"
              set:html={TitleLineShortSvg}
            />
          </div>
        </div>
        <!-- Attribution -->
        <div class="mt-5 flex w-full justify-end">
          <span
            id="credit"
            class="mr-4 max-w-full text-[40px] text-nowrap font-stretch-condensed opacity-50 drop-shadow-lg"
          >
          </span>
        </div>
      </div>
    </div>

    <!-- Hairline fix -->
    <div class="pointer-events-none absolute inset-0 z-40 shadow-[inset_0_0_0_1px_#000]"></div>
  </div>
</Layout>
