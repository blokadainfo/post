---
import Layout from '@layouts/Template.astro';
import Logo from '@assets/brand/logos/logo.svg';
import TitleLineLong from '@assets/templates/accents/title/long.svg';
import TitleLineShort from '@assets/templates/accents/title/short.svg';
---

<Layout viewportWidth={1080}>
  <!-- 1080×1350 canvas -->
  <div id="post" class="relative h-[1350px] w-[1080px] overflow-hidden bg-black">
    <!-- Background -->
    <img
      id="bg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 z-0 h-full w-full object-cover"
    />

    <!-- Darken overlay (controlled by client) -->
    <div id="shade" class="pointer-events-none absolute inset-0 z-10 bg-black" style="opacity:0;">
    </div>

    <!-- Gradient overlay -->
    <div
      class="absolute inset-0 z-20 h-full w-full bg-gradient-to-b from-black/90 from-10% to-black/0"
    >
    </div>
    <div
      class="absolute inset-0 z-20 h-full w-full bg-gradient-to-t from-black/70 from-0% to-black/0 to-20%"
    >
    </div>

    <!-- Foreground content -->
    <div class="absolute inset-0 z-30 p-8 font-['Akzidenz-Grotesk_Pro'] text-white">
      <!-- Logo -->
      <img src={Logo.src} alt="Logo" class="absolute top-10 left-9 size-30 drop-shadow-lg" />

      <!-- Main text block -->
      <div class="absolute top-40 left-52 w-[75%] max-w-[75%]">
        <!-- Paragraph -->
        <div class="font-bold font-stretch-normal">
          <p
            id="paragraph"
            class="text-[46px] leading-tight text-pretty whitespace-pre-line drop-shadow-lg"
          >
          </p>
        </div>

        <!-- Accent lines -->
        <div class="mt-8 [transform:scaleX(-1)] space-y-1">
          <img src={TitleLineLong.src} alt="" aria-hidden="true" class="block h-auto w-full" />
          <img src={TitleLineShort.src} alt="" aria-hidden="true" class="block h-auto w-5/12" />
        </div>
      </div>

      <!-- Footer -->
      <div class="font-stretch-condensed opacity-50">
        <span id="credit" class="absolute bottom-12 left-9 text-[40px] text-nowrap drop-shadow-lg"
        ></span>

        <span class="absolute right-9 bottom-12 text-[40px] drop-shadow-lg">blokada.info</span>
      </div>
    </div>

    <!-- Hairline fix -->
    <div class="pointer-events-none absolute inset-0 z-40 shadow-[inset_0_0_0_1px_#000]"></div>
  </div>
</Layout>
