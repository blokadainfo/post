---
/* eslint-disable astro/no-set-html-directive */
import Layout from '@layouts/Template.astro';
import LogoSvg from '@assets/brand/logos/logo.svg?raw';
import TitleLineLongSvg from '@assets/templates/accents/title/long.svg?raw';
import TitleLineShortSvg from '@assets/templates/accents/title/short.svg?raw';
---

<Layout viewportWidth={1080}>
  <!-- 1080×1350 canvas -->
  <div id="post" class="relative h-[1350px] w-[1080px] overflow-hidden bg-black">
    <!-- Background -->
    <img
      id="bg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 z-0 h-full w-full object-cover"
    />

    <!-- Darken overlay (controlled by client) -->
    <div id="shade" class="pointer-events-none absolute inset-0 z-10 bg-black" style="opacity:0;">
    </div>

    <!-- Gradient overlay -->
    <div
      class="absolute inset-0 z-20 h-full w-full bg-gradient-to-t from-black/90 from-10% to-black/0"
    >
    </div>
    <div
      class="absolute inset-0 z-20 h-full w-full bg-gradient-to-b from-black/70 from-0% to-black/0 to-20%"
    >
    </div>

    <!-- Foreground content -->
    <div class="absolute inset-0 z-30 p-8 font-['Akzidenz-Grotesk_Pro'] text-white">
      <!-- Logo -->
      <span
        role="img"
        aria-label="Logo"
        class="absolute top-10 left-9 size-30 drop-shadow-lg [&_svg]:block [&_svg]:size-full"
        set:html={LogoSvg}
      />

      <!-- Main text block -->
      <div class="absolute bottom-50 left-20 w-[75%] max-w-[75%]">
        <!-- Accent lines -->
        <div class="mb-3 space-y-1">
          <span
            aria-hidden="true"
            class="block w-5/12 [transform:scaleY(-1)] [&_svg]:block [&_svg]:h-auto [&_svg]:w-full"
            set:html={TitleLineShortSvg}
          />
          <span
            aria-hidden="true"
            class="block w-full [transform:scaleY(-1)] [&_svg]:block [&_svg]:h-auto [&_svg]:w-full"
            set:html={TitleLineLongSvg}
          />
        </div>

        <!-- Paragraph -->
        <div class="font-bold font-stretch-normal">
          <p
            id="paragraph"
            class="text-[46px] leading-tight text-pretty whitespace-pre-line drop-shadow-lg"
          >
          </p>
        </div>
      </div>

      <!-- Footer -->
      <div class="font-stretch-condensed">
        <span
          id="credit"
          class="absolute bottom-12 left-9 text-[40px] text-nowrap opacity-50 drop-shadow-lg"
        ></span>

        <span class="absolute right-9 bottom-12 text-[40px] opacity-50 drop-shadow-lg"
          >blokada.info</span
        >
      </div>
    </div>

    <!-- Hairline fix -->
    <div class="pointer-events-none absolute inset-0 z-40 shadow-[inset_0_0_0_1px_#000]"></div>
  </div>
</Layout>
