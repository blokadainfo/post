---
import Layout from '@layouts/Layout.astro';
import { execFileSync } from 'node:child_process';
import { existsSync, mkdirSync, readdirSync } from 'node:fs';
import { join, relative } from 'node:path';

type AssetItem = {
  name: string;
  href: string;
  filename: string;
  category: string;
  relativePath: string;
};

type AssetSection = {
  key: string;
  title: string;
  items: AssetItem[];
};

function formatName(filename: string): string {
  return filename
    .replace(/\.[^.]+$/, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\b\w/g, (m) => m.toUpperCase());
}

const publicResursiDir = join(process.cwd(), 'public', 'resursi');
const publicResursiZipDir = join(process.cwd(), 'public', 'resursi-zips');

function slugify(value: string): string {
  return (
    value
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '') || 'general'
  );
}

function getRootDefs(): Pick<AssetSection, 'key' | 'title'>[] {
  if (!existsSync(publicResursiDir)) return [];

  return readdirSync(publicResursiDir, { withFileTypes: true })
    .filter((entry) => entry.isDirectory())
    .map((entry) => ({
      key: entry.name,
      title: formatName(entry.name),
    }))
    .sort((a, b) => a.title.localeCompare(b.title));
}

function walkFiles(dir: string): string[] {
  let files: string[] = [];
  for (const entry of readdirSync(dir, { withFileTypes: true })) {
    const fullPath = join(dir, entry.name);
    if (entry.isDirectory()) {
      files = files.concat(walkFiles(fullPath));
      continue;
    }
    if (entry.isFile()) files.push(fullPath);
  }
  return files;
}

function buildItemsForRoot(rootKey: string): AssetItem[] {
  const rootDir = join(publicResursiDir, rootKey);
  let files: string[] = [];
  try {
    files = walkFiles(rootDir);
  } catch {
    files = [];
  }

  return files
    .map((filePath) => {
      const normalized = filePath.replace(/\\/g, '/');
      const rootDirNormalized = rootDir.replace(/\\/g, '/');
      const afterRoot = relative(rootDirNormalized, normalized).replace(/\\/g, '/');
      const segments = afterRoot.split('/').filter(Boolean);
      const filename = segments.at(-1) ?? 'asset';
      const categorySegments = segments.slice(0, -1);
      const category = categorySegments.length ? categorySegments.join(' / ') : 'General';
      const href = `/resursi/${rootKey}/${afterRoot}`.replace(/\\/g, '/');

      return {
        name: formatName(filename),
        href,
        filename,
        category,
        relativePath: afterRoot,
      } satisfies AssetItem;
    })
    .sort((a, b) => a.category.localeCompare(b.category) || a.filename.localeCompare(b.filename));
}

function ensureCategoryZip(rootKey: string, category: string, items: AssetItem[]) {
  if (items.length === 0) return null;

  const rootDir = join(publicResursiDir, rootKey);
  const zipDir = join(publicResursiZipDir, rootKey);
  const zipFilename = `${slugify(category)}_${slugify(rootKey)}.zip`;
  const zipPath = join(zipDir, zipFilename);

  mkdirSync(zipDir, { recursive: true });

  try {
    execFileSync('zip', ['-q', '-r', zipPath, ...items.map((item) => item.relativePath)], {
      cwd: rootDir,
    });
  } catch {
    return null;
  }

  return `/resursi-zips/${rootKey}/${zipFilename}`;
}

const rootDefs = getRootDefs();

const sections: AssetSection[] = rootDefs
  .map((root) => ({
    ...root,
    items: buildItemsForRoot(root.key),
  }))
  .filter((section) => section.items.length > 0);

const categoryArchiveHrefs = new Map<string, string>();

sections.forEach((section) => {
  const categories = [...new Set(section.items.map((item) => item.category))];

  categories.forEach((category) => {
    const items = section.items.filter((item) => item.category === category);
    const href = ensureCategoryZip(section.key, category, items);
    if (href) categoryArchiveHrefs.set(`${section.key}:${category}`, href);
  });
});
---

<Layout>
  <main
    class="min-h-svh bg-[#0a0a0a] bg-[linear-gradient(rgba(255,255,255,0.12)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.12)_1px,transparent_1px)] bg-[size:28px_28px] px-6 py-10 text-neutral-100"
  >
    <div class="mx-auto w-full max-w-[1100px]">
      <header class="mb-8 border border-neutral-800 bg-black/80 p-6 backdrop-blur-[12px] sm:p-8">
        <div class="flex items-start justify-between gap-4 border-b border-neutral-800 pb-5">
          <div>
            <p class="text-[0.72rem] tracking-[0.08em] text-neutral-400 uppercase">Resources</p>
            <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Asset Downloads</h1>
          </div>
        </div>
      </header>

      <section
        class="relative z-10 mb-8 border border-neutral-800 bg-black/80 p-5 backdrop-blur-[12px] sm:p-6"
      >
        <div class="flex flex-wrap items-end gap-4">
          <div class="relative min-w-[220px]">
            <span class="mb-2 block text-[0.72rem] tracking-[0.08em] text-neutral-400 uppercase">
              Type
            </span>
            <button
              id="asset-type-trigger"
              type="button"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-controls="asset-type-menu"
              class="flex w-full cursor-pointer items-center justify-between rounded-[0.85rem] border border-neutral-700 bg-black/75 px-4 py-3 text-sm text-neutral-100 focus-visible:border-white focus-visible:ring-1 focus-visible:ring-white focus-visible:outline-none focus-visible:ring-inset"
            >
              <span id="asset-type-value">Select type</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-4 w-4 text-neutral-400"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6"></path>
              </svg>
            </button>
            <div
              id="asset-type-menu"
              role="listbox"
              tabindex="-1"
              class="absolute top-[calc(100%+0.5rem)] left-0 hidden w-full overflow-hidden rounded-[0.85rem] border border-neutral-800 bg-neutral-950/98 p-2 backdrop-blur-[14px]"
            >
              {
                sections.map((section) => (
                  <button
                    id={`asset-type-option-${section.key}`}
                    type="button"
                    role="option"
                    data-asset-type-option
                    data-value={section.key}
                    data-label={section.title}
                    aria-selected="false"
                    class="flex w-full cursor-pointer items-center justify-between rounded-[0.7rem] px-3 py-2 text-left text-sm text-neutral-200 hover:bg-white/8 focus-visible:border-white focus-visible:ring-1 focus-visible:ring-white focus-visible:outline-none focus-visible:ring-inset"
                  >
                    <span>{section.title}</span>
                  </button>
                ))
              }
            </div>
          </div>

          <button
            id="asset-filter-reset"
            type="button"
            class="cursor-pointer rounded-[0.85rem] border border-neutral-700 bg-black/75 px-4 py-3 text-sm tracking-[0.08em] text-neutral-200 uppercase focus-visible:border-white focus-visible:ring-1 focus-visible:ring-white focus-visible:outline-none focus-visible:ring-inset"
          >
            Reset
          </button>
        </div>
      </section>

      <div class="space-y-8">
        {
          sections.map((section) => {
            const categories = [...new Set(section.items.map((item) => item.category))];

            return (
              <section
                class="border border-neutral-800 bg-black/80 p-5 backdrop-blur-[12px] sm:p-6"
                data-asset-section
                data-section-key={section.key}
              >
                <div class="mb-5 border-b border-neutral-800 pb-4">
                  <h2 class="text-lg font-semibold text-neutral-100">{section.title}</h2>
                </div>

                <div class="space-y-5">
                  {categories.map((category) => (
                    <div data-asset-category-group data-category={category}>
                      <div class="mb-2 flex items-center justify-between gap-3">
                        <h3 class="text-[0.72rem] tracking-[0.08em] text-neutral-400 uppercase">
                          {category}
                        </h3>
                        {categoryArchiveHrefs.get(`${section.key}:${category}`) && (
                          <a
                            href={categoryArchiveHrefs.get(`${section.key}:${category}`)}
                            download
                            class="inline-flex cursor-pointer items-center rounded-[0.7rem] border border-neutral-700 bg-black/75 px-3 py-2 text-[0.72rem] tracking-[0.08em] text-neutral-200 uppercase focus-visible:border-white focus-visible:ring-1 focus-visible:ring-white focus-visible:outline-none focus-visible:ring-inset"
                          >
                            Download ZIP
                          </a>
                        )}
                      </div>
                      <ul class="space-y-3">
                        {section.items
                          .filter((item) => item.category === category)
                          .map((item) => (
                            <li class="flex flex-wrap items-center justify-between gap-3 rounded-[0.85rem] border border-neutral-800 bg-black/55 px-4 py-3">
                              <div class="min-w-0">
                                <p class="truncate text-sm font-medium">{item.name}</p>
                                <p class="truncate text-xs text-neutral-500">{item.filename}</p>
                              </div>
                              <div class="flex items-center gap-2">
                                <a
                                  href={item.href}
                                  target="_blank"
                                  rel="noreferrer"
                                  class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-[0.85rem] border border-neutral-700 bg-black/75 text-neutral-200 focus-visible:border-white focus-visible:ring-1 focus-visible:ring-white focus-visible:outline-none focus-visible:ring-inset"
                                  aria-label={`Preview ${item.name}`}
                                  title="Preview"
                                >
                                  <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="h-4 w-4"
                                    aria-hidden="true"
                                  >
                                    <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6" />
                                    <circle cx="12" cy="12" r="3" />
                                  </svg>
                                </a>
                                <a
                                  href={item.href}
                                  download={item.filename}
                                  class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-[0.85rem] border border-neutral-700 bg-neutral-100 text-neutral-950 focus-visible:border-white focus-visible:ring-1 focus-visible:ring-white focus-visible:outline-none focus-visible:ring-inset"
                                  aria-label={`Download ${item.name}`}
                                  title="Download"
                                >
                                  <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="h-4 w-4"
                                    aria-hidden="true"
                                  >
                                    <path d="M12 3v11m-5-4 5 5 5-5M4 20h16" />
                                  </svg>
                                </a>
                              </div>
                            </li>
                          ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </section>
            );
          })
        }
      </div>
    </div>
  </main>

  <script>
    import * as typeFilter from '../lib/preuzmi-resurse/type-filter.ts';
    typeFilter.initAssetTypeFilter();
  </script>
</Layout>
